generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  name          String
  role          String   @default("admin")
  createdAt     DateTime @default(now())

  stockMovements    StockMovement[] @relation("RecordedMovements")
  verifiedMovements StockMovement[] @relation("VerifiedMovements")
  tintingRecords    TintingRecord[]
  stockOpnames      StockOpname[]
  purchaseOrders    PurchaseOrder[]
}

model Supplier {
  id            Int      @id @default(autoincrement())
  name          String
  contactName   String?
  phone         String?
  email         String?
  address       String?
  leadTimeDays  Int      @default(0)
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products       Product[]
  batches        Batch[]
  purchaseOrders PurchaseOrder[]
}

model Product {
  id            Int      @id @default(autoincrement())
  supplierId    Int?
  name          String
  sku           String   @unique
  category      String?
  brand         String?
  paintType     String?
  colorName     String?
  colorCode     String?
  finishType    String?
  tintBase      String?
  packageSize   String?
  unit          String   @default("pcs")
  rackLocation  String?
  minStock      Int      @default(0)
  currentStock  Int      @default(0)
  purchasePrice Float    @default(0)
  sellingPrice  Float    @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  supplier         Supplier?         @relation(fields: [supplierId], references: [id])
  batches          Batch[]
  stockMovements   StockMovement[]
  tintingAsBase    TintingRecord[]   @relation("BaseProduct")
  tintingAsComp    TintingComponent[]
  opnameItems      StockOpnameItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([name])
  @@index([sku])
  @@index([colorCode])
  @@index([category])
  @@index([brand])
}

model Batch {
  id              Int      @id @default(autoincrement())
  productId       Int
  supplierId      Int?
  batchNumber     String
  quantity        Int      @default(0)
  initialQuantity Int      @default(0)
  receivedDate    DateTime @default(now())
  expiryDate      DateTime?
  unitCost        Float    @default(0)
  invoiceNumber   String?
  conditionStatus String   @default("good")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product         Product           @relation(fields: [productId], references: [id])
  supplier        Supplier?         @relation(fields: [supplierId], references: [id])
  stockMovements  StockMovement[]
  tintingComps    TintingComponent[]
  opnameItems     StockOpnameItem[]

  @@unique([productId, batchNumber])
  @@index([expiryDate])
}

model StockMovement {
  id                  Int      @id @default(autoincrement())
  productId           Int
  batchId             Int?
  userId              Int
  type                String   // INBOUND, OUTBOUND, ADJUSTMENT, TINTING
  reason              String
  quantity            Int      // signed: positive = in, negative = out
  stockBefore         Int
  stockAfter          Int
  sourceLocation      String?
  destinationLocation String?
  notes               String?
  createdAt           DateTime @default(now())

  // Manager verification of stock in/out (separation of duties)
  verificationStatus  String   @default("pending") // pending | verified | flagged
  verifiedById        Int?
  verifiedAt          DateTime?
  verificationNote    String?

  product    Product @relation(fields: [productId], references: [id])
  batch      Batch?  @relation(fields: [batchId], references: [id])
  user       User    @relation("RecordedMovements", fields: [userId], references: [id])
  verifiedBy User?   @relation("VerifiedMovements", fields: [verifiedById], references: [id])

  @@index([productId])
  @@index([createdAt])
  @@index([type])
  @@index([verificationStatus])
}

model TintingRecord {
  id             Int      @id @default(autoincrement())
  baseProductId  Int
  userId         Int
  colorCode      String?
  colorName      String?
  formulaNotes   String?
  outputQuantity Float
  outputUnit     String   @default("L")
  notes          String?
  createdAt      DateTime @default(now())

  baseProduct Product            @relation("BaseProduct", fields: [baseProductId], references: [id])
  user        User               @relation(fields: [userId], references: [id])
  components  TintingComponent[]
}

model TintingComponent {
  id                 Int     @id @default(autoincrement())
  tintingRecordId    Int
  componentProductId Int
  batchId            Int?
  quantityUsed       Float
  unit               String  @default("ml")

  tintingRecord    TintingRecord @relation(fields: [tintingRecordId], references: [id], onDelete: Cascade)
  componentProduct Product       @relation(fields: [componentProductId], references: [id])
  batch            Batch?        @relation(fields: [batchId], references: [id])
}

model StockOpname {
  id         Int      @id @default(autoincrement())
  userId     Int
  status     String   @default("draft") // draft, confirmed, cancelled
  opnameDate DateTime @default(now())
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User              @relation(fields: [userId], references: [id])
  items StockOpnameItem[]
}

model StockOpnameItem {
  id                 Int     @id @default(autoincrement())
  stockOpnameId      Int
  productId          Int
  batchId            Int?
  systemQuantity     Int
  physicalQuantity   Int
  differenceQuantity Int
  applied            Boolean @default(false)
  notes              String?

  stockOpname StockOpname @relation(fields: [stockOpnameId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])
  batch       Batch?      @relation(fields: [batchId], references: [id])
}

model PurchaseOrder {
  id           Int      @id @default(autoincrement())
  supplierId   Int?
  userId       Int
  status       String   @default("draft") // draft, ordered, received, cancelled
  orderDate    DateTime @default(now())
  expectedDate DateTime?
  invoiceNumber String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supplier Supplier?           @relation(fields: [supplierId], references: [id])
  user     User                @relation(fields: [userId], references: [id])
  items    PurchaseOrderItem[]

  @@index([status])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id               Int   @id @default(autoincrement())
  purchaseOrderId  Int
  productId        Int
  quantityOrdered  Int
  quantityReceived Int   @default(0)
  unitCost         Float @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
}
