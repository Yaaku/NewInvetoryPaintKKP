# Copy this file to .env and adjust values.

# SQLite for local/MVP. Swap to a PostgreSQL URL for production.
DATABASE_URL="file:./dev.db"

# iron-session cookie secret — MUST be at least 32 characters.
# Generate a strong value before deploying, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_PASSWORD="change-this-to-a-long-random-secret-of-at-least-32-characters!!"

# --- Optional: public app URL (used in digest email links) ---
# APP_URL="https://your-app.example.com"

# --- Optional: stock digest (low-stock / expiry email) ---
# Secret guarding the /api/cron/digest endpoint (Bearer token).
# CRON_SECRET="another-long-random-secret"
# Resend (https://resend.com) email delivery. Without these, the digest
# runs as a dry-run preview only.
# RESEND_API_KEY="re_..."
# DIGEST_FROM="InventoryCat <stok@yourdomain.com>"
# DIGEST_TO="owner@example.com,manajer@example.com"
